#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "$0")/../../../" && pwd)"
PYTHON=/Users/aniket/.pyenv/versions/3.12.0/bin/python3

# If the server is already running, just open the browser
if lsof -i :7821 -sTCP:LISTEN -t >/dev/null 2>&1; then
    open "http://localhost:7821"
    exit 0
fi

"$PYTHON" "$SCRIPT_DIR/dashboard.py"
